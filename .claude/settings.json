{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "lean-rs-skills": {
      "source": {
        "source": "github",
        "repo": "jcreinhold/lean-rs-skills"
      }
    }
  },
  "enabledPlugins": {
    "lean-rs-skills@lean-rs-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ffi-boundary-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.rs) rustfmt \"$f\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ]
  }
}
