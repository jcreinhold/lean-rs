root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.rs]
indent_style = space
indent_size = 4

[*.lean]
indent_style = space
indent_size = 2
max_line_length = 100

[*.tex]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 4

[*.js]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.sh]
indent_style = tab

[Makefile]
indent_style = tab
